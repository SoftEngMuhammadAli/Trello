  color: var(--app-accent);
}

.bg-accent-soft {
  background-color: var(--app-accent-soft);
}

.shadow-soft {
  box-shadow: var(--app-shadow);
}

.app-card {
  border: 1px solid var(--app-border);
  background: linear-gradient(180deg, var(--app-panel), var(--app-panel-soft));
  border-radius: 1rem;
  box-shadow: var(--app-shadow);
}

.app-dot {
  width: 0.52rem;
  height: 0.52rem;
  border-radius: 999px;
  background: linear-gradient(120deg, var(--app-accent), #14b8a6);
}

.profile-field {
  width: 100%;
  border-radius: 0.85rem;
  border: 1px solid var(--app-border);
  background: var(--app-panel);
  color: var(--app-text);
  padding: 0.72rem 0.9rem;
  outline: none;
  transition: border-color 0.18s ease, box-shadow 0.18s ease;
}

.profile-field:focus {
  border-color: var(--app-accent);
  box-shadow: 0 0 0 3px var(--app-accent-soft);
}

.profile-field:disabled {
  opacity: 0.78;
  cursor: not-allowed;
}

.modal-enter {
  animation: modalEnter 160ms ease;
}

@keyframes modalEnter {
  from {
    opacity: 0;
    transform: translateY(14px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(18px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.rise-in {
  animation: riseIn 260ms ease;
}

.custom-scrollbar {
  scrollbar-width: thin;
  scrollbar-color: var(--app-border) transparent;
}

.custom-scrollbar::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
  background: var(--app-border);
  border-radius: 999px;
}
